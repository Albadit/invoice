{
  "name": "invoice-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile:frontend": "docker compose -f frontend/docker-compose.yml up -d --build",
    "compile:backend": "docker compose -f supabase/docker-compose.yml up -d --build",
    "predev:frontend": "npm --prefix frontend install",
    "dev:frontend": "npm --prefix frontend run dev",
    "db:gen": "tsx ./tools/supabase/generate-types.ts",
    "db:migrate": "tsx ./tools/supabase/db-migrate.ts",
    "db:schema": "tsx ./tools/supabase/db-schema.ts",
    "db:seed": "tsx ./tools/supabase/db-seed.ts",
    "db:drop": "tsx ./tools/supabase/db-drop.ts",
    "db:reset": "npm-run-all \"db:drop -- --yes\" db:schema db:seed"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "dotenv": "^17.2.4",
    "npm-run-all": "^1.1.3",
    "pg": "^8.18.0",
    "tsx": "^4.21.0"
  }
}
