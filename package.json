{
  "name": "invoice-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile:frontend": "docker compose -f frontend/docker-compose.yml up -d --build",
    "compile:backend": "docker compose -f supabase/docker-compose.yml up -d --build",
    "predev:frontend": "npm --prefix frontend install",
    "dev:frontend": "npm --prefix frontend run dev",
    "db:gen": "tsx ./tools/supabase/generate-types.ts",
    "db:migrate": "tsx ./tools/supabase/db.ts migrate",
    "db:schema": "tsx ./tools/supabase/db.ts schema",
    "db:seed": "tsx ./tools/supabase/db.ts seed",
    "db:drop": "tsx ./tools/supabase/db.ts drop --yes",
    "db:reset": "tsx ./tools/supabase/db.ts reset --yes"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "dotenv": "^17.2.4",
    "npm-run-all": "^1.1.3",
    "pg": "^8.18.0",
    "tsx": "^4.21.0"
  }
}
